[user]
	name = xtinyrabbit
	email = xtinyrabbit@gmail.com

[init]
	defaultBranch = main

[core]
	pager = delta
	excludesFile = ~/.config/git/gitignore_global

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[rerere]
	enabled = true
